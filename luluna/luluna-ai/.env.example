# Backend API Configuration
# Buraya istediğin AI servisinin URL'ini gir
API_BASE_URL=http://127.0.0.1:8000

# AI Service API Key/Token
# Cloudflare, OpenAI, Google Gemini, Anthropic veya başka servis için API key
API_KEY=your_api_key_here

# Geliştirici Modu (true/false)
DEVELOPER_MODE=false

# Geliştirici Modu Aktivasyon Kodu
DEVELOPER_CODE=//81//

# Bu dosyayı .env olarak kopyalayın ve kendi ayarlarınızı yapın
# cp .env.example .env
