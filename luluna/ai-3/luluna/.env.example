# ============================================================
# AI MOTOR SEÇİMİ
# Sadece bu satırı değiştirin — başka hiçbir şeye dokunmaya gerek yok.
# Seçenekler: gemini | openai | claude | cloudflare
# ============================================================
AI_PROVIDER=gemini

# ============================================================
# GOOGLE GEMINI
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# OPENAI (GPT-4o)
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ============================================================
# ANTHROPIC (Claude)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ============================================================
# CLOUDFLARE WORKERS AI (LLaVA)
# ============================================================
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_MODEL=@cf/llava-hf/llava-1.5-7b-hf

# ============================================================
# GELİŞTİRİCİ MODU
# false: Çocuk güvenli mod | true: Kısıtlama yok
# ============================================================
DEVELOPER_MODE=false

# Bu dosyayı kopyalayıp .env yapın ve kendi keylerini girin:
#   cp .env.example .env
